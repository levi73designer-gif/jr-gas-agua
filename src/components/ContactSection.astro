---
const WA_NUMBER = '5519996896714';
const WA_MESSAGE = encodeURIComponent('Olá! Gostaria de fazer um pedido JR Gás e Água.');
const WA_LINK = `https://wa.me/${WA_NUMBER}?text=${WA_MESSAGE}`;
---

<section class="section" style="background-color: var(--color-bg-elevated);">
  <div class="section__container">
    <h2
      class="reveal font-bold uppercase tracking-wider text-center mb-3"
      style="font-family: var(--font-display); font-size: clamp(1.5rem, 4vw, 2rem); letter-spacing: 0.015em; color: var(--color-text);"
    >
      Entre em contato
    </h2>
    <p
      class="reveal text-center mb-10 md:mb-12 max-w-2xl mx-auto"
      style="color: var(--color-text-secondary); font-size: 1rem; line-height: 1.625;"
    >
      Fale conosco pelo WhatsApp ou telefone. Estamos prontos para atender você.
    </p>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
      <!-- WhatsApp -->
      <a
        href={WA_LINK}
        target="_blank"
        rel="noopener noreferrer"
        class="reveal rounded-lg p-6 text-center transition-all duration-200 min-h-[44px]"
        style="background-color: var(--color-surface); border: 1px solid var(--color-border);"
        aria-label="Enviar mensagem pelo WhatsApp"
      >
        <div class="mx-auto mb-4 flex items-center justify-center" style="width: 48px; height: 48px;">
          <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="#25D366">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.85 1.787-1.164 2.336-.85.547.294 1.874 1.228 2.16.997.297-.148 1.04-.577 1.2-.964.123-.387.084-.712.042-.772-.042-.06-.148-.099-.347-.223zm-5.421 7.403h-.004a9.188 9.188 0 01-4.897-1.417l-.34-.203-3.541.93.946-3.46-.224-.357a9.19 9.19 0 01-1.41-4.908C2.665 7.04 6.89 2.816 12.051 2.816c2.448 0 4.749 1.007 6.477 2.834a9.103 9.103 0 012.634 6.475c-.003 5.167-4.227 9.39-9.391 9.39h-.024zM20.52 3.449C18.24 1.246 15.24 0 12.045 0 5.463 0 .104 5.334.101 11.893c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.88 11.88 0 005.683 1.448h.005c6.585 0 11.946-5.336 11.949-11.896 0-3.176-1.24-6.165-3.495-8.411z"/>
          </svg>
        </div>
        <h3 class="font-bold uppercase tracking-wider mb-2" style="font-family: var(--font-display); font-size: 1rem; color: var(--color-text);">
          WhatsApp
        </h3>
        <p style="font-size: 0.875rem; color: var(--color-text-secondary); line-height: 1.625;">
          (19) 99689-6714
        </p>
        <span class="inline-block mt-3 font-semibold uppercase tracking-wider text-xs" style="color: #25D366;">
          Enviar mensagem
        </span>
      </a>

      <!-- Phone -->
      <a
        href="tel:+5519981737556"
        class="reveal rounded-lg p-6 text-center transition-all duration-200 min-h-[44px]"
        style="background-color: var(--color-surface); border: 1px solid var(--color-border);"
        aria-label="Ligar para (19) 98173-7556"
      >
        <div class="mx-auto mb-4 flex items-center justify-center" style="width: 48px; height: 48px;">
          <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="var(--color-water-light)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 16.92z"/></svg>
        </div>
        <h3 class="font-bold uppercase tracking-wider mb-2" style="font-family: var(--font-display); font-size: 1rem; color: var(--color-text);">
          Telefone
        </h3>
        <p style="font-size: 0.875rem; color: var(--color-text-secondary); line-height: 1.625;">
          (19) 98173-7556
        </p>
        <span class="inline-block mt-3 font-semibold uppercase tracking-wider text-xs" style="color: var(--color-water-light);">
          Ligar agora
        </span>
      </a>

      <!-- Hours -->
      <div
        class="reveal rounded-lg p-6 text-center"
        style="background-color: var(--color-surface); border: 1px solid var(--color-border);"
      >
        <div class="mx-auto mb-4 flex items-center justify-center" style="width: 48px; height: 48px;">
          <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="var(--color-gas-light)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
        </div>
        <h3 class="font-bold uppercase tracking-wider mb-2" style="font-family: var(--font-display); font-size: 1rem; color: var(--color-text);">
          Horários
        </h3>
        <p style="font-size: 0.875rem; color: var(--color-text-secondary); line-height: 1.625;">
          Seg–Sex: 7h às 21h<br/>
          Sáb: 8h às 20h<br/>
          Dom: 8h às 15h
        </p>
      </div>

      <!-- Payment -->
      <div
        class="reveal rounded-lg p-6 text-center"
        style="background-color: var(--color-surface); border: 1px solid var(--color-border);"
      >
        <div class="mx-auto mb-4 flex items-center justify-center" style="width: 48px; height: 48px;">
          <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="var(--color-text-secondary)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="4" width="22" height="16" rx="2" ry="2"/><line x1="1" y1="10" x2="23" y2="10"/></svg>
        </div>
        <h3 class="font-bold uppercase tracking-wider mb-2" style="font-family: var(--font-display); font-size: 1rem; color: var(--color-text);">
          Pagamento
        </h3>
        <p style="font-size: 0.875rem; color: var(--color-text-secondary); line-height: 1.625;">
          Dinheiro<br/>
          PIX<br/>
          Cartão (crédito e débito)
        </p>
      </div>
    </div>

    <!-- CTA Final -->
    <div class="reveal mt-12 md:mt-16 text-center">
      <div
        class="rounded-lg p-8 md:p-12"
        style="background: linear-gradient(135deg, rgba(196,58,10,0.15) 0%, rgba(58,76,192,0.15) 100%); border: 1px solid var(--color-border);"
      >
        <h3
          class="font-bold uppercase tracking-wider mb-3"
          style="font-family: var(--font-display); font-size: clamp(1.25rem, 3vw, 1.75rem); color: var(--color-text);"
        >
          Faça seu pedido agora
        </h3>
        <p class="mb-6 max-w-lg mx-auto" style="font-size: 1rem; color: var(--color-text-secondary); line-height: 1.625;">
          Um clique no WhatsApp e seu gás ou água chega na sua porta.
        </p>
        <a
          href={WA_LINK}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center justify-center gap-2 min-h-[48px] px-8 py-3 rounded-md font-semibold text-white uppercase tracking-wider text-sm"
          style="background: linear-gradient(135deg, #C43A0A 0%, #E8621A 100%); transition: filter var(--duration-fast) var(--ease-out), box-shadow var(--duration-fast) var(--ease-out), transform var(--duration-fast) var(--ease-out);"
          aria-label="Pedir via WhatsApp"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.85 1.787-1.164 2.336-.85.547.294 1.874 1.228 2.16.997.297-.148 1.04-.577 1.2-.964.123-.387.084-.712.042-.772-.042-.06-.148-.099-.347-.223zm-5.421 7.403h-.004a9.188 9.188 0 01-4.897-1.417l-.34-.203-3.541.93.946-3.46-.224-.357a9.19 9.19 0 01-1.41-4.908C2.665 7.04 6.89 2.816 12.051 2.816c2.448 0 4.749 1.007 6.477 2.834a9.103 9.103 0 012.634 6.475c-.003 5.167-4.227 9.39-9.391 9.39h-.024zM20.52 3.449C18.24 1.246 15.24 0 12.045 0 5.463 0 .104 5.334.101 11.893c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.88 11.88 0 005.683 1.448h.005c6.585 0 11.946-5.336 11.949-11.896 0-3.176-1.24-6.165-3.495-8.411z"/>
          </svg>
          Pedir via WhatsApp
        </a>
      </div>
    </div>
  </div>
</section>
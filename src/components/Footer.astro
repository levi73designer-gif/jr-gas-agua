---
const WA_LINK = `https://wa.me/5519996896714?text=${encodeURIComponent('Olá! Gostaria de fazer um pedido JR Gás e Água.')}`;
---

<div class="accent-bar" role="presentation" aria-hidden="true"></div>

<footer style="background-color: #0A0A0A; color: #FFFFFF;">
  <div class="section" style="padding-top: var(--space-12); padding-bottom: var(--space-12);">
    <div class="section__container">
      <!-- Grid -->
      <div class="grid grid-cols-1 gap-8 md:grid-cols-2 lg:grid-cols-4 lg:gap-8">
        <!-- Column 1: Brand -->
        <div>
          <div class="flex items-center gap-2 mb-3">
            <img
              src="/images/JR-logo.png"
              alt="JR Gás e Água"
              width="36"
              height="36"
              style="height: 36px; width: auto; object-fit: contain; filter: brightness(0) invert(1);"
            />
            <span class="font-bold text-lg tracking-wide" style="font-family: var(--font-display); text-transform: uppercase; letter-spacing: 0.04em;">
              <span style="color: #E8621A;">JR</span> <span style="color: rgba(255,255,255,0.7);">Gás e Água</span>
            </span>
          </div>
          <p class="text-sm leading-relaxed" style="color: rgba(255,255,255,0.5);">
            Distribuindo mais que produtos, distribuímos qualidade!
          </p>
        </div>

        <!-- Column 2: Navigation -->
        <div>
          <span class="block font-semibold text-xs tracking-widest uppercase mb-4" style="font-family: var(--font-display); color: rgba(255,255,255,0.9);">
            Navegação
          </span>
          <ul class="space-y-2">
            <li><a href="/" class="text-sm min-h-[44px] flex items-center" style="color: rgba(255,255,255,0.6);">Início</a></li>
            <li><a href="/produtos" class="text-sm min-h-[44px] flex items-center" style="color: rgba(255,255,255,0.6);">Produtos</a></li>
            <li><a href="/sobre" class="text-sm min-h-[44px] flex items-center" style="color: rgba(255,255,255,0.6);">Sobre</a></li>
            <li><a href="/contato" class="text-sm min-h-[44px] flex items-center" style="color: rgba(255,255,255,0.6);">Contato</a></li>
          </ul>
        </div>

        <!-- Column 3: Contact -->
        <div>
          <span class="block font-semibold text-xs tracking-widest uppercase mb-4" style="font-family: var(--font-display); color: rgba(255,255,255,0.9);">
            Contato
          </span>
          <ul class="space-y-3">
            <li class="flex items-center gap-2 min-h-[44px]">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="#25D366" aria-hidden="true" style="flex-shrink: 0;"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
              <a href={WA_LINK} target="_blank" rel="noopener noreferrer" class="text-sm" style="color: #25D366;">(19) 99689-6714</a>
            </li>
            <li class="flex items-center gap-2 min-h-[44px]">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="color: rgba(255,255,255,0.6); flex-shrink: 0;"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 16.92z"/></svg>
              <span class="text-sm" style="color: rgba(255,255,255,0.6);">(19) 98173-7556</span>
            </li>
          </ul>
        </div>

        <!-- Column 4: Hours -->
        <div>
          <span class="block font-semibold text-xs tracking-widest uppercase mb-4" style="font-family: var(--font-display); color: rgba(255,255,255,0.9);">
            Horários
          </span>
          <ul class="space-y-2 text-sm" style="color: rgba(255,255,255,0.6);">
            <li class="flex items-center gap-2 min-h-[44px]">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="color: rgba(255,255,255,0.4); flex-shrink: 0;"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
              Seg–Sex: 7h às 21h
            </li>
            <li class="flex items-center gap-2 min-h-[44px]">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="color: rgba(255,255,255,0.4); flex-shrink: 0;"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
              Sáb: 8h às 20h
            </li>
            <li class="flex items-center gap-2 min-h-[44px]">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="color: rgba(255,255,255,0.4); flex-shrink: 0;"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
              Dom: 8h às 15h
            </li>
          </ul>
        </div>
      </div>

      <!-- Copyright -->
      <div class="mt-12 pt-6 text-center" style="border-top: 1px solid rgba(255,255,255,0.1);">
        <p class="text-xs uppercase tracking-widest" style="color: rgba(255,255,255,0.4);">
          JR Gás e Água — Santa Gertrudes, SP
        </p>
      </div>
    </div>
  </div>
</footer>
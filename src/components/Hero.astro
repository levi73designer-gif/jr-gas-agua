---
const WA_LINK = `https://wa.me/5519996896714?text=${encodeURIComponent('Olá! Gostaria de fazer um pedido JR Gás e Água.')}`;
---

<section
  class="relative flex items-center"
  style="min-height: 80vh; padding: var(--space-12) var(--space-5);"
>
  <!-- Background with gradient -->
  <div
    class="absolute inset-0"
    style="background: linear-gradient(135deg, #C43A0A 0%, #3A4CC0 100%); z-index: 0;"
    aria-hidden="true"
  ></div>
  <!-- Overlay for text readability -->
  <div
    class="absolute inset-0"
    style="background: linear-gradient(180deg, rgba(0,0,0,0.4) 0%, rgba(0,0,0,0.65) 100%); z-index: 1;"
    aria-hidden="true"
  ></div>

  <div class="relative z-10 w-full section__container">
    <!-- Accent bar -->
    <div
      class="mb-6 md:mb-8"
      style="width: 80px; height: 4px; background: #FFFFFF; border-radius: 2px;"
      aria-hidden="true"
    ></div>

    <h1
      class="font-black uppercase tracking-wider leading-none"
      style="font-family: var(--font-display); font-size: clamp(2rem, 8vw, 4.5rem); letter-spacing: 0.02em; color: #FFFFFF;"
    >
      Distribuindo mais que produtos,
      <span style="color: #FFFFFF; opacity: 0.9;">
        distribuímos qualidade!
      </span>
    </h1>

    <p
      class="mt-6 max-w-2xl"
      style="font-family: var(--font-body); font-size: 1.125rem; font-weight: 500; color: rgba(255,255,255,0.85); line-height: 1.625;"
    >
      Gás de cozinha, gás industrial, água mineral e acessórios. Entrega rápida em Santa Gertrudes e região.
    </p>

    <div class="flex flex-col sm:flex-row gap-4 mt-8">
      <!-- Primary CTA: WhatsApp -->
      <a
        href={WA_LINK}
        target="_blank"
        rel="noopener noreferrer"
        class="flex items-center justify-center gap-2 min-h-[48px] px-6 py-3 rounded-md font-semibold text-white uppercase tracking-wider text-sm"
        style="background: linear-gradient(135deg, #C43A0A 0%, #E8621A 100%); transition: filter var(--duration-fast) var(--ease-out), box-shadow var(--duration-fast) var(--ease-out), transform var(--duration-fast) var(--ease-out);"
        aria-label="Pedir via WhatsApp"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.85 1.787-1.164 2.336-.85.547.294 1.874 1.228 2.16.997.297-.148 1.04-.577 1.2-.964.123-.387.084-.712.042-.772-.042-.06-.148-.099-.347-.223zm-5.421 7.403h-.004a9.188 9.188 0 01-4.897-1.417l-.34-.203-3.541.93.946-3.46-.224-.357a9.19 9.19 0 01-1.41-4.908C2.665 7.04 6.89 2.816 12.051 2.816c2.448 0 4.749 1.007 6.477 2.834a9.103 9.103 0 012.634 6.475c-.003 5.167-4.227 9.39-9.391 9.39h-.024zM20.52 3.449C18.24 1.246 15.24 0 12.045 0 5.463 0 .104 5.334.101 11.893c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.88 11.88 0 005.683 1.448h.005c6.585 0 11.946-5.336 11.949-11.896 0-3.176-1.24-6.165-3.495-8.411z"/>
        </svg>
        Pedir via WhatsApp
      </a>

      <!-- Secondary CTA: Products -->
      <a
        href="/produtos"
        class="flex items-center justify-center gap-2 min-h-[48px] px-6 py-3 rounded-md font-semibold uppercase tracking-wider text-sm border"
        style="color: #FFFFFF; border-color: rgba(255,255,255,0.6); transition: background-color var(--duration-fast) var(--ease-out), color var(--duration-fast) var(--ease-out), border-color var(--duration-fast) var(--ease-out);"
        aria-label="Ver nossos produtos"
      >
        Ver Produtos
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
      </a>
    </div>
  </div>

  <!-- Desktop height adjustment -->
  <style>
    @media (min-width: 1024px) {
      section { min-height: 90vh !important; }
    }
  </style>
</section>
---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ContactSection from '../components/ContactSection.astro';

const WA_LINK = `https://wa.me/5519996896714?text=${encodeURIComponent('Olá! Gostaria de saber mais sobre a JR Gás e Água.')}`;
---

<Layout title="Sobre — JR Gás e Água" description="Conheça a história da JR Gás e Água. Mais de 10 anos distribuindo gás e água mineral com qualidade em Santa Gertrudes - SP.">
  <Header slot="header" />

  <!-- About Hero -->
  <section class="section" style="background-color: var(--color-bg); padding-top: calc(var(--space-12) + 4.5rem);">
    <div class="section__container">
      <div class="reveal">
        <div
          class="mb-6"
          style="width: 80px; height: 4px; background: linear-gradient(135deg, #C43A0A 0%, #3A4CC0 100%); border-radius: 2px;"
          aria-hidden="true"
        ></div>

        <h1
          class="font-black uppercase tracking-wider leading-none mb-4"
          style="font-family: var(--font-display); font-size: clamp(1.75rem, 5vw, 3rem); color: var(--color-text);"
        >
          Sobre a JR Gás e Água
        </h1>
        <p
          class="max-w-2xl"
          style="font-family: var(--font-body); font-size: 1rem; font-weight: 400; color: var(--color-text-secondary); line-height: 1.625;"
        >
          Mais de uma década distribuindo gás e água mineral com compromisso, segurança e agilidade.
        </p>
      </div>
    </div>
  </section>

  <!-- History -->
  <section class="section" style="background-color: var(--color-bg-elevated);">
    <div class="section__container max-w-4xl">
      <div class="reveal">
        <h2
          class="font-bold uppercase tracking-wider mb-6"
          style="font-family: var(--font-display); font-size: clamp(1.5rem, 4vw, 2rem); color: var(--color-text);"
        >
          Nossa história
        </h2>
        <p class="mb-4" style="font-size: 1rem; color: var(--color-text-secondary); line-height: 1.625;">
          A JR Gás e Água nasceu em Santa Gertrudes com uma missão simples: entregar com rapidez e respeito. Começamos como um pequeno distribuidor local e hoje atendemos centenas de famílias e empresas da região.
        </p>
        <p class="mb-4" style="font-size: 1rem; color: var(--color-text-secondary); line-height: 1.625;">
          Santa Gertrudes é polo industrial. Sabemos que o gás P20 para empilhadeiras não pode esperar, assim como o botijão P13 do almoço de domingo. Cada pedido é tratado com a mesma urgência e cuidado.
        </p>
        <p style="font-size: 1rem; color: var(--color-text-secondary); line-height: 1.625;">
          Nosso slogan diz tudo: <em style="color: var(--color-gas-light); font-style: normal; font-weight: 600;">distribuímos mais que produtos, distribuímos qualidade.</em> Qualidade no atendimento, na entrega, no produto e na relação com o cliente.
        </p>
      </div>
    </div>
  </section>

  <!-- Values -->
  <section class="section" style="background-color: var(--color-bg);">
    <div class="section__container">
      <h2
        class="reveal font-bold uppercase tracking-wider text-center mb-10 md:mb-12"
        style="font-family: var(--font-display); font-size: clamp(1.5rem, 4vw, 2rem); color: var(--color-text);"
      >
        Nossos valores
      </h2>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-5 gap-6">
        {[
          { title: 'Energia', desc: 'Vem do fogo. É a urgência de cada entrega, a pressa de resolver.', color: 'var(--color-gas-light)' },
          { title: 'Confiança', desc: 'Vem da água. É a tranquilidade de quem sabe que pode contar com a gente.', color: 'var(--color-water-light)' },
          { title: 'Qualidade', desc: 'Produtos originais, entrega no prazo, palavra cumprida.', color: 'var(--color-text)' },
          { title: 'Clareza', desc: 'Preço justo, sem surpresas. Informação clara do início ao fim.', color: 'var(--color-text-secondary)' },
          { title: 'Profissionalismo', desc: 'Equipe treinada, veículos em dia, segurança em primeiro lugar.', color: 'var(--color-text-secondary)' },
        ].map((value) => (
          <div class="reveal rounded-lg p-6 text-center" style="background-color: var(--color-surface); border: 1px solid var(--color-border);">
            <h3 class="font-bold uppercase tracking-wider mb-2" style={`font-family: var(--font-display); font-size: 1rem; color: ${value.color};`}>
              {value.title}
            </h3>
            <p style="font-size: 0.875rem; color: var(--color-text-secondary); line-height: 1.625;">
              {value.desc}
            </p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Coverage -->
  <section class="section" style="background-color: var(--color-bg-elevated);">
    <div class="section__container max-w-3xl">
      <div class="reveal text-center">
        <h2
          class="font-bold uppercase tracking-wider mb-6"
          style="font-family: var(--font-display); font-size: clamp(1.5rem, 4vw, 2rem); color: var(--color-text);"
        >
          Área de cobertura
        </h2>

        <div class="grid grid-cols-1 sm:grid-cols-3 gap-6 mb-8">
          <!-- Santa Gertrudes - active -->
          <div class="rounded-lg p-6" style="background-color: var(--color-surface); border: 2px solid var(--color-gas);">
            <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="var(--color-gas-light)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mx-auto mb-3"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
            <h3 class="font-bold uppercase tracking-wider mb-1" style="font-family: var(--font-display); font-size: 1rem; color: var(--color-gas-light);">
              Santa Gertrudes
            </h3>
            <p class="text-xs uppercase tracking-widest" style="color: var(--color-success);">Atendimento ativo</p>
          </div>

          <!-- Rio Claro - coming soon -->
          <div class="rounded-lg p-6" style="background-color: var(--color-surface); border: 1px solid var(--color-border);">
            <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="var(--color-text-muted)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mx-auto mb-3"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
            <h3 class="font-bold uppercase tracking-wider mb-1" style="font-family: var(--font-display); font-size: 1rem; color: var(--color-text-muted);">
              Rio Claro
            </h3>
            <p class="text-xs uppercase tracking-widest" style="color: var(--color-warning);">Em breve</p>
          </div>

          <!-- Cordeirópolis - coming soon -->
          <div class="rounded-lg p-6" style="background-color: var(--color-surface); border: 1px solid var(--color-border);">
            <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="var(--color-text-muted)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mx-auto mb-3"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
            <h3 class="font-bold uppercase tracking-wider mb-1" style="font-family: var(--font-display); font-size: 1rem; color: var(--color-text-muted);">
              Cordeirópolis
            </h3>
            <p class="text-xs uppercase tracking-widest" style="color: var(--color-warning);">Em breve</p>
          </div>
        </div>

        <p class="mb-8" style="font-size: 1rem; color: var(--color-text-secondary); line-height: 1.625;">
          Estamos expandindo! Se você é de Rio Claro ou Cordeirópolis, entre em contato — podemos atender sua região em breve.
        </p>

        <a
          href={WA_LINK}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center justify-center gap-2 min-h-[48px] px-8 py-3 rounded-md font-semibold text-white uppercase tracking-wider text-sm"
          style="background: linear-gradient(135deg, #C43A0A 0%, #E8621A 100%); transition: filter var(--duration-fast) var(--ease-out), box-shadow var(--duration-fast) var(--ease-out), transform var(--duration-fast) var(--ease-out);"
          aria-label="Fale conosco pelo WhatsApp"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.85 1.787-1.164 2.336-.85.547.294 1.874 1.228 2.16.997.297-.148 1.04-.577 1.2-.964.123-.387.084-.712.042-.772-.042-.06-.148-.099-.347-.223zm-5.421 7.403h-.004a9.188 9.188 0 01-4.897-1.417l-.34-.203-3.541.93.946-3.46-.224-.357a9.19 9.19 0 01-1.41-4.908C2.665 7.04 6.89 2.816 12.051 2.816c2.448 0 4.749 1.007 6.477 2.834a9.103 9.103 0 012.634 6.475c-.003 5.167-4.227 9.39-9.391 9.39h-.024zM20.52 3.449C18.24 1.246 15.24 0 12.045 0 5.463 0 .104 5.334.101 11.893c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.88 11.88 0 005.683 1.448h.005c6.585 0 11.946-5.336 11.949-11.896 0-3.176-1.24-6.165-3.495-8.411z"/>
          </svg>
          Fale conosco pelo WhatsApp
        </a>
      </div>
    </div>
  </section>

  <!-- Safety -->
  <section class="section" style="background-color: var(--color-bg);">
    <div class="section__container max-w-3xl">
      <div class="reveal">
        <h2
          class="font-bold uppercase tracking-wider mb-6"
          style="font-family: var(--font-display); font-size: clamp(1.5rem, 4vw, 2rem); color: var(--color-text);"
        >
          Nosso diferencial
        </h2>
        <p class="mb-4" style="font-size: 1rem; color: var(--color-text-secondary); line-height: 1.625;">
          A JR Gás e Água vai além da entrega. Nosso time orienta sobre boas práticas de segurança com gás, desde o armazenamento correto até o manuseio seguro do botijão.
        </p>
        <p style="font-size: 1rem; color: var(--color-text-secondary); line-height: 1.625;">
          Acreditamos que boa convivência começa com respeito. Respeito pelo prazo, pelo produto e, acima de tudo, pela segurança da sua família.
        </p>
      </div>
    </div>
  </section>

  <ContactSection />
  <Footer slot="footer" />
</Layout>